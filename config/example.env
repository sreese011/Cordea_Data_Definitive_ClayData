# =============================================================================
# Claydata: Definitive → Clay Healthcare Executive List Workflow
# Copy this file to .env and fill in your values
# =============================================================================

# Definitive Healthcare API (required for API mode - automatic report download)
# Get credentials from https://sts.defhc.com
DEFINITIVE_USERNAME=your_username
DEFINITIVE_PASSWORD=your_password

# Report save folder (API downloads)
# Default: Contact Lists/ in project root
# Override: set to full path, e.g. C:\Reports\ or D:\Data\ContactLists
REPORT_SAVE_FOLDER=

# Geocoding (optional - improves city → ZIP lookup)
# Get free token at https://www.mapbox.com
# Leave blank to use Nominatim (free, may be slower/rate-limited)
MAPBOX_ACCESS_TOKEN=
